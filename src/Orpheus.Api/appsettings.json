{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Orpheus": {
    "Speech": {
      "Provider": "deterministic-wav",
      "WindowsSapi": {
        "VoiceName": null,
        "TimeoutSeconds": 30
      }
    },
    "State": {
      "StoreLastOriginalText": true
    }
  }
}
